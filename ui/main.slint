import {
    MaterialWindow,
    MaterialTypography,
    MaterialText,
    MaterialPalette,
    FloatingActionButton,
    PopupMenu,
    MenuItem,
    IconButton,
    MaterialWindowAdapter,
} from "@material";
import { Palette } from "std-widgets.slint";
import { Clock } from "components/clock.slint";
import { Login, User } from "components/login.slint";
import { SessionSelector } from "components/session_selector.slint";
import { PowerBottomSheet } from "components/power_menu.slint";
import { Background } from "components/background.slint";
import { AppStyle } from "style.slint";

import "./fonts/FlexRounded-R.ttf";
import "./fonts/FlexRounded-M.ttf";
import "./fonts/FlexRounded-B.ttf";
import "./fonts/MaterialDesignIcons.ttf";

export struct Compositor {
    name: string,
    exec: string,
}

export { MaterialPalette, MaterialTypography, User, MenuItem, AppStyle }

export struct UserData {
    user_name: string,
    real_name: string,
    password: string,
}

export component GreeterWindow inherits MaterialWindow {
    default-font-family: AppStyle.default-font-family != "" ? AppStyle.default-font-family : "sans-serif";

    in property <image> background-original;
    in property <image> background-blurred;
    in property <color> background-fallback-color;
    in property <string> hours: "00";
    in property <string> minutes: "00";
    in property <string> date: "";
    in property <string> greeting-msg: "Welcome!";

    in property <[User]> users;
    in property <[MenuItem]> user-menu-items;
    in property <image> composer-icon;
    in-out property <int> selected-user-index: -1;
    in-out property <string> auth-error;

    in property <[Compositor]> compositors;
    in property <[MenuItem]> compositor-menu-items;
    in-out property <int> selected-compositor-index: 0;

    in-out property <bool> is-authenticating: false;
    in-out property <bool> show-login: false;

    // Exported statically compiled icons for Rust backend
    out property <image> default-user-icon: @image-url("icons/person.svg");
    out property <image> default-session-icon: @image-url("icons/auto_awesome_mosaic.svg");

    callback set-color-scheme(bool);
    set-color-scheme(is-dark) => {
        Palette.color-scheme = is-dark ? ColorScheme.dark : ColorScheme.light;
    }

    callback login(string, string);
    callback compositor-selected(int);
    callback user-selected(int);

    callback shutdown();
    callback reboot();
    callback sleep();
    callback hibernate();

    // Background Layer
    Background {
        original: root.background-original;
        blurred: root.background-blurred;
        fallback-color: root.background-fallback-color;
        show-login: root.show-login;
    }

    // Interaction Area
    TouchArea {
        clicked => {
            if (!root.show-login) {
                root.show-login = true;
            }
        }

        // Centered Content
        if (!root.show-login): Clock {
            hours: root.hours;
            minutes: root.minutes;
            date: root.date;
        }

        // Bottom Message (Unlock)
        if (!root.show-login): VerticalLayout {
            alignment: end;
            padding-bottom: 60px;

            MaterialText {
                text: "Press any key to unlock";
                style: MaterialTypography.body-large;
                color: MaterialPalette.on-background.with-alpha(0.5);
                horizontal-alignment: center;
            }
        }

        // Login Card
        if (root.show-login): Rectangle {
            width: 380px;
            height: 500px;
            background: MaterialPalette.surface-container.with-alpha(AppStyle.window-opacity);
            border_radius: 32px;

            Login {
                users: root.users;
                user-menu-items: root.user-menu-items;
                selected-user-index <=> root.selected-user-index;
                composer-icon: root.composer-icon;
                auth-error <=> root.auth-error;
                greeting-msg: root.greeting-msg;
                is-authenticating <=> root.is-authenticating;

                login(user_name, pwd) => {
                    root.login(user_name, pwd);
                }

                user-selected(idx) => {
                    root.user-selected(idx);
                }
            }
        }
    }

    // Bottom UI
    if (root.show-login): Rectangle {
        VerticalLayout {
            alignment: end;
            padding-bottom: 24px;
            padding-left: 24px;
            padding-right: 24px;

            Rectangle {
                // Power Menu Trigger
                HorizontalLayout {
                    alignment: center;
                    IconButton {
                        icon: @image-url("icons/settings_power.svg");
                        width: 48px;
                        height: 48px;
                        clicked => {
                            power_menu.show();
                        }
                    }
                }

                // Session Selection
                HorizontalLayout {
                    alignment: end;
                    SessionSelector {
                        items: root.compositor-menu-items;
                        current-name: root.compositors[root.selected-compositor-index].name;
                        icon: @image-url("icons/dashboard_2_gear.svg");
                        selected(idx) => {
                            root.selected-compositor-index = idx;
                            root.compositor-selected(idx);
                        }
                    }
                }
            }
        }
    }

    // Power Menu Instance
    power_menu := PowerBottomSheet {
        width: root.width;
        height: root.height;
        background_opacity: AppStyle.window-opacity;

        shutdown => {
            root.shutdown();
        }
        reboot => {
            root.reboot();
        }
        sleep => {
            root.sleep();
        }
        hibernate => {
            root.hibernate();
        }
    }

    // Keyboard Interaction
    forward-focus: fs;
    fs := FocusScope {
        key-pressed(event) => {
            if (!root.show-login) {
                root.show-login = true;
                return accept;
            }
            if (event.text == Key.Escape) {
                root.show-login = false;
                return accept;
            }
            reject
        }
    }
}
