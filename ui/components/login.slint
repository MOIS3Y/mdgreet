import {
    MaterialTypography,
    MaterialPalette,
    MaterialText,
    IconButton,
    FilledIconButton,
    DropDownMenu,
    MenuItem,
    TextButton,
} from "@material";
import { TextField } from "text_field.slint";
import { Icons } from "../../material-1.0/ui/icons/icons.slint";

export struct User {
    user_name: string,
    real_name: string,
    initials: string,
    avatar: image,
}

export { MenuItem }

export component Login {
    in property <[User]> users;
    in property <[MenuItem]> user-menu-items;
    in-out property <int> selected-user-index: -1;
    in property <image> composer-icon;
    in-out property <string> auth-error;

    callback login(string, string); // user_name, password
    callback user-selected(int);

    property <bool> manual-user-entry: false;
    property <bool> show-password: false;
    property <string> manual-username: "";
    property <string> password-text: "";

    // Clear error when password or user changes
    changed password-text => {
        root.auth-error = "";
    }
    changed selected-user-index => {
        root.auth-error = "";
    }
    changed manual-user-entry => {
        root.auth-error = "";
    }

    // Container for absolute positioning
    width: 100%;
    height: 100%;

    // Content (Centered)
    VerticalLayout {
        width: 100%;
        height: 100%;
        padding_bottom: 40px;
        spacing: 16px;
        alignment: center;

        // Avatar
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 100px;
                height: 100px;
                border_radius: 50px;
                background: MaterialPalette.primary-container;
                clip: true;

                if (!root.manual-user-entry && root.selected-user-index >= 0 && root.users[root.selected-user-index].avatar.width > 0): Image {
                    source: root.users[root.selected-user-index].avatar;
                    width: 100%;
                    height: 100%;
                    image-fit: cover;
                }

                if (!root.manual-user-entry && root.selected-user-index >= 0 && root.users[root.selected-user-index].avatar.width == 0 && root.users[root.selected-user-index].initials != ""): MaterialText {
                    text: root.users[root.selected-user-index].initials;
                    style: MaterialTypography.display-small;
                    color: MaterialPalette.on-primary-container;
                    vertical_alignment: center;
                    horizontal_alignment: center;
                }

                if (root.manual-user-entry || root.selected-user-index < 0 || (root.users[root.selected-user-index].avatar.width == 0 && root.users[root.selected-user-index].initials == "")): Image {
                    source: @image-url("../icons/account_circle.svg");
                    width: 80%;
                    height: 80%;
                    colorize: MaterialPalette.on-primary-container;
                }
            }
        }

        // User Entry Block
        VerticalLayout {
            spacing: 0;
            alignment: center;

            if (!root.manual-user-entry): HorizontalLayout {
                alignment: center;
                DropDownMenu {
                    width: 300px;
                    label: "User";
                    items: root.user-menu-items;
                    current_index <=> root.selected-user-index;
                    leading_icon: @image-url("../icons/person.svg");

                    selected(idx) => {
                        root.user-selected(idx);
                    }
                }
            }

            if (root.manual-user-entry): HorizontalLayout {
                alignment: center;
                TextField {
                    width: 300px;
                    label: "Username";
                    text <=> root.manual-username;
                    leading_icon: @image-url("../icons/person.svg");
                }
            }
        }

        // Password Block
        HorizontalLayout {
            alignment: center;
            password_input := TextField {
                width: 300px;
                label: "Password";
                text <=> root.password-text;
                input_type: root.show-password ? InputType.text : InputType.password;
                has_error: root.auth-error != "";
                supporting_text: root.auth-error;
                leading_icon: @image-url("../icons/passkey.svg");
                trailing_icon: root.show-password ? @image-url("../icons/visibility.svg") : @image-url("../icons/visibility_lock.svg");

                trailing_icon_clicked => {
                    root.show-password = !root.show-password;
                }

                accepted => {
                    root.login(
                        root.manual-user-entry ? root.manual-username : (root.selected-user-index >= 0 ? root.users[root.selected-user-index].user_name : ""),
                        self.text);
                }
            }
        }

        // Toggle Button
        HorizontalLayout {
            alignment: end;
            padding_right: 40px;
            TextButton {
                text: root.manual-user-entry ? "Select from list" : "Not listed?";
                clicked => {
                    root.manual-user-entry = !root.manual-user-entry;
                }
            }
        }
    }

    // Login Button
    FilledIconButton {
        icon: @image-url("../icons/fingerprint.svg");
        width: 64px;
        height: 64px;
        x: (parent.width - self.width) / 2;
        y: parent.height - 56px;

        clicked => {
            root.login(
                root.manual-user-entry ? root.manual-username : (root.selected-user-index >= 0 ? root.users[root.selected-user-index].user_name : ""),
                root.password-text);
        }
    }
}
